# Site/runtime
PUBLIC_SITE_URL=https://example.com
PUBLIC_MEDIA_BASE_URL=https://media.example.com
PUBLIC_CF_ANALYTICS_TOKEN=

# Telegram API (required for sync)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_STRING_SESSION=
TELEGRAM_CHANNEL=your_channel_username

# Cloudflare R2 (required for media upload)
R2_ENDPOINT=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=https://media.example.com

# Sync behavior
SYNC_RECENT_WINDOW=250
MAX_VIDEO_BYTES=26214400
