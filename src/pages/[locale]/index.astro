---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import { getLocalePosts, getSiteText, pageTitle } from '@/lib/content';
import { LOCALES, UI } from '@/lib/i18n';
import type { Locale } from '@/lib/types';

export function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
if (!LOCALES.includes(locale)) {
  throw new Error('Unsupported locale route');
}

const siteText = getSiteText(locale);
const posts = getLocalePosts(locale, { includeDeleted: false, includeDraft: false }).slice(0, 12);

const title = pageTitle(siteText.title, locale);
const description = siteText.subtitle || (locale === 'ru' ? 'Зеркало постов канала о жизни, путешествиях и технологиях.' : 'Mirror of channel posts about life, travel, and tech.');
---

<BaseLayout
  title={title}
  description={description}
  locale={locale}
  canonicalPath={`/${locale}/`}
  enPath="/en/"
  ruPath="/ru/"
>
  <section class="hero">
    <h1>{siteText.title}</h1>
    {siteText.subtitle && <p>{siteText.subtitle}</p>}
    {siteText.bodyHtml && <div set:html={siteText.bodyHtml} />}
  </section>

  <section>
    <h2>{UI[locale].latestPosts}</h2>
    {posts.length === 0 ? (
      <p>{locale === 'ru' ? 'Пока нет опубликованных постов для этого языка.' : 'No published posts yet for this language.'}</p>
    ) : (
      <div class="posts-grid">
        {posts.map((post) => (
          <PostCard post={post} locale={locale} />
        ))}
      </div>
    )}

    <p>
      <a href={`/${locale}/archive/1/`}>{UI[locale].allPosts}</a>
    </p>
  </section>
</BaseLayout>
